<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".InventoryActivity"
    android:background="@color/background_light"
    android:padding="16dp"
    android:paddingTop="32dp">


    <!-- Title Row -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo -->
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_inventory_logo"
            android:tint="@color/brand_primary"
            android:layout_marginBottom="6dp"
            android:contentDescription="Inventory Logo"/>

        <!-- Title -->
        <TextView
            android:id="@+id/textInventoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SmartStock Dashboard"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

        <!-- Add Button -->
        <Button
            android:id="@+id/buttonAddItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/primary_button_bg"
            android:text="Enter New Items"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:padding="12dp"/>
    </LinearLayout>

    <!-- SMS -->
    <LinearLayout
        android:id="@+id/smsRow"
        android:layout_width="259dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerContainer">

        <TextView
            android:id="@+id/textSmsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="SMS Alerts"
            android:textSize="16sp" />

        <Switch
            android:id="@+id/switchSms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="" />

        <EditText
            android:id="@+id/editPhoneNumber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:hint="Phone #"
            android:inputType="phone" />

    </LinearLayout>


    <!-- Header Row Container -->
    <LinearLayout
        android:id="@+id/headerRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@id/smsRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Item Header -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Item"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"/>

        <!-- Qty Header -->
        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="Qty"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:gravity="center"/>

        <!-- Actions Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:text="Remove/Add/Delete"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:id="@+id/recyclerInventory"
        app:layout_constraintTop_toBottomOf="@id/dividerHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- Divider Under Headers -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:id="@+id/dividerHeader"
        android:background="#CCCCCC"
        app:layout_constraintTop_toBottomOf="@id/headerRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>